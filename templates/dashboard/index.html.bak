{# ══════════════════════════════════════════════════════════════════════ #}
{# DASHBOARD UTAMA — Halaman utama setelah login                        #}
{# ══════════════════════════════════════════════════════════════════════ #}
{# File ini menampilkan ringkasan data bisnis:                          #}
{# - Ringkasan Penjualan (total aset, harga beli, harga jual)          #}
{# - Estimasi Keuntungan & Profit Margin                                #}
{# - Grafik Penjualan Bulan Ini (area chart)                           #}
{# - Grafik Keuntungan per Cabang (bar chart)                          #}
{# - Grafik Biaya per Kategori (bar chart)                             #}
{# - Slider Penjualan Mingguan (Swiper carousel)                       #}
{# - Slider Metode Pembayaran (Swiper carousel)                        #}
{# - Tabel Produk Terlaris                                             #}
{# - Tabel Pengguna Terbaru                                            #}
{# - Timeline Aktivitas Terkini                                        #}
{# - Filter Tanggal, Jam Realtime, Lokasi, IP Address                  #}
{#                                                                      #}
{# Terhubung dengan:                                                    #}
{# - apps/dashboard/views.py → DashboardView menyiapkan semua data     #}
{# - config/context_processors.py → Data user dan pengaturan global    #}
{# - apps/produk/models.py → Data produk dan stok                      #}
{# - apps/penjualan/models.py → Data penjualan                        #}
{# - apps/pembelian/models.py → Data pembelian                        #}
{# - apps/biaya/models.py → Data biaya operasional                     #}
{# ══════════════════════════════════════════════════════════════════════ #}

{# Extend layout utama — mewarisi struktur HTML (header, sidebar, footer) #}
{% extends layout_path %}

{# Load template tags yang dibutuhkan #}
{% load static %}         {# Tag {% static %} untuk URL file statis (CSS, JS, gambar) #}
{% load currency_filters %} {# Filter kustom |rupiah untuk format mata uang Indonesia #}
{% load i18n %}            {# Tag internasionalisasi (multi-bahasa) #}

{# Judul halaman — muncul di tab browser #}
{% block title %}Dashboard - eCommerce{% endblock title %}

{# ═══ VENDOR CSS — Library CSS eksternal yang dibutuhkan dashboard ═══ #}
{% block vendor_css %}
{{ block.super }}  {# Memuat CSS dari parent template terlebih dahulu #}
{# DataTables CSS — untuk tabel interaktif (sorting, searching, pagination) #}
<link rel="stylesheet" href="{% static 'vendor/libs/datatables-bs5/datatables.bootstrap5.css' %}" />
<link rel="stylesheet" href="{% static 'vendor/libs/datatables-responsive-bs5/responsive.bootstrap5.css' %}" />
{# ApexCharts CSS — untuk grafik/chart (penjualan, keuntungan, biaya) #}
<link rel="stylesheet" href="{% static 'vendor/libs/apex-charts/apex-charts.css' %}" />
{# Swiper CSS — untuk slider/carousel (penjualan mingguan, metode pembayaran) #}
<link rel="stylesheet" href="{% static 'vendor/libs/swiper/swiper.css' %}" />
{% endblock vendor_css %}

{# ═══ VENDOR JS — Library JavaScript eksternal ═══ #}
{% block vendor_js %}
{{ block.super }}  {# Memuat JS dari parent template terlebih dahulu #}
{# DataTables JS — engine tabel interaktif #}
<script src="{% static 'vendor/libs/datatables-bs5/datatables-bootstrap5.js' %}"></script>
{# ApexCharts JS — library untuk membuat grafik/chart interaktif #}
<script src="{% static 'vendor/libs/apex-charts/apexcharts.js' %}"></script>
{# Swiper JS — library untuk slider/carousel yang responsif #}
<script src="{% static 'vendor/libs/swiper/swiper.js' %}"></script>
{% endblock vendor_js %}

{% block page_css %}
{{ block.super }}
<link rel="stylesheet" href="{% static 'vendor/css/pages/cards-statistics.css' %}" />
<link rel="stylesheet" href="{% static 'vendor/css/pages/cards-analytics.css' %}" />
{# CSS Kustom Dashboard — Styling badge dan layout yang tidak ada di Bootstrap #}
<style>
  /* Badge angka pada slider penjualan mingguan (latar semi-transparan putih) */
  .weekly-sales-text-bg-primary {
    background-color: rgba(255, 255, 255, 0.2);
    color: #fff !important;
    padding: 0.2rem 0.5rem;
    border-radius: 0.375rem;
  }

  /* Badge angka penjualan (latar ungu semi-transparan) */
  .sales-text-bg {
    background-color: rgba(102, 108, 255, 0.16);
    color: #666cff !important;
    padding: 0.35rem 0.75rem;
    border-radius: 0.375rem;
    font-weight: 500;
    min-width: 90px;
    text-align: center;
    display: inline-block;
    font-size: 0.8125rem;
    white-space: nowrap;
  }

  /* Badge statistik metode pembayaran pada slider */
  /* Efek hover: warna lebih gelap + sedikit naik + bayangan */
  .payment-stat-badge {
    background-color: rgba(102, 108, 255, 0.12);
    color: #666cff;
    padding: 0.4rem 0.75rem;
    border-radius: 0.5rem;
    font-weight: 600;
    min-width: 100px;
    text-align: center;
    display: inline-block;
    font-size: 0.8125rem;
    white-space: nowrap;
    cursor: pointer;
    transition: all 0.2s ease;
    border: 1px solid rgba(102, 108, 255, 0.08);
  }
  .payment-stat-badge:hover {
    background-color: rgba(102, 108, 255, 0.25);
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(102, 108, 255, 0.15);
  }

  /* ═══════════════════════════════════════════════════════════════════
     MOBILE ≤ 576px — Hanya styling SPESIFIK dashboard
     (Aturan umum sudah di global styles.html)
     ═══════════════════════════════════════════════════════════════════ */
  @media (max-width: 576px) {

    /* ─── Card subtitle & info dashboard ─── */
    .card .card-subtitle { font-size: 0.75rem; }
    .card .card-info p.mb-0 { font-size: 0.8rem; }

    /* ─── Ringkasan Penjualan: gap rapat ─── */
    .card-body.d-flex.justify-content-between.flex-wrap {
      gap: 0.75rem !important;
    }
    .card-body .d-flex.align-items-center.gap-3 {
      gap: 0.5rem !important;
    }

    /* ─── Badge slider (khusus dashboard) ─── */
    .payment-stat-badge {
      min-width: 70px;
      padding: 0.3rem 0.5rem;
      font-size: 0.75rem;
    }
    .sales-text-bg {
      min-width: 65px;
      padding: 0.25rem 0.5rem;
      font-size: 0.75rem;
    }

    /* ─── Weekly Sales Swiper ─── */
    .swiper-container .swiper-slide {
      padding: 0.875rem !important;
    }
    .swiper-container .swiper-slide .row {
      --bs-gutter-x: 0.5rem;
    }
    .weekly-sales-img {
      max-height: 140px !important;
      width: 140px !important;
    }
    .swiper-sales .swiper-slide {
      padding: 0.875rem !important;
    }

    /* ─── Timeline ─── */
    .timeline .timeline-item { padding-bottom: 0.75rem; }
    .timeline .timeline-header { margin-bottom: 0.375rem !important; }
    .timeline .timeline-event p { font-size: 0.8rem; margin-bottom: 0.375rem !important; }

    /* ─── Chart min-height ─── */
    #liveVisitors, #visitsByDayChart { min-height: 180px; }

    /* ─── Divider Gudang & Produk ─── */
    .divider.divider-vertical { margin: 0 !important; }

    /* ─── Filter bar margin ─── */
    .dash-filter-card { margin-bottom: 0.75rem !important; }

    /* ─── Icon posisi absolute (Estimasi/Profit) ─── */
    .card .position-absolute[style*="top: 1.5rem; right: 1.5rem"] {
      top: 0.875rem !important;
      right: 0.875rem !important;
    }

    /* ─── Marketing slider compact ─── */
    .swiper-sales .d-flex.align-items-center.mt-4 { margin-top: 0.75rem !important; }
    .swiper-sales .d-flex.flex-column.ms-4 { margin-left: 0.75rem !important; }
    .swiper-sales .row.g-3 { --bs-gutter-y: 0.375rem; --bs-gutter-x: 0.375rem; }
    .swiper-sales .mt-4:last-child { margin-top: 0.75rem !important; }

    /* ─── Total Pembelian/Biaya ─── */
    .card .d-flex.align-items-center.gap-4 { gap: 0.75rem !important; }
  }
</style>
{% endblock page_css %}

{% block page_js %}
{# ═══ DATA JSON DARI SERVER (Django → JavaScript) ═══ #}
{# Tag json_script Django mengkonversi data Python ke JSON yang aman untuk HTML #}
{# Data ini akan dibaca oleh JavaScript untuk membuat grafik chart #}
{{ sales_chart_data|json_script:"sales-chart-data" }}     {# Data angka penjualan per tanggal #}
{{ sales_chart_labels|json_script:"sales-chart-labels" }}   {# Label tanggal untuk sumbu X chart #}
{{ live_visitors_data|json_script:"live-visitors-data" }}   {# Data keuntungan per cabang #}
{{ visits_by_day_data|json_script:"visits-by-day-data" }}   {# Data biaya per kategori #}
{% if cabang_profit_data %}
{{ cabang_profit_data|json_script:"cabang-names-raw" }}
{% endif %}

{{ block.super }}
<script src="{% static 'vendor/libs/swiper/swiper.js' %}"></script>
<script>
  'use strict';  // Mode ketat JavaScript — mencegah penggunaan variabel tanpa deklarasi

  // ═══════════════════════════════════════════════════════════════
  // INISIALISASI SETELAH DOM SIAP
  // ═══════════════════════════════════════════════════════════════
  // Semua kode chart dan Swiper berjalan setelah HTML selesai dimuat
  document.addEventListener('DOMContentLoaded', function () {

    // ─── DETEKSI MODE TERANG/GELAP ───
    // Memilih palet warna yang sesuai berdasarkan tema
    // isDarkStyle = variabel global dari template helper
    let cardColor, headingColor, labelColor, borderColor, legendColor;

    if (isDarkStyle) {
      // Warna untuk mode gelap (dark mode)
      cardColor = config.colors_dark.cardColor;
      headingColor = config.colors_dark.headingColor;
      labelColor = config.colors_dark.textMuted;
      legendColor = config.colors_dark.bodyColor;
      borderColor = config.colors_dark.borderColor;
    } else {
      // Warna untuk mode terang (light mode)
      cardColor = config.colors.cardColor;
      headingColor = config.colors.headingColor;
      labelColor = config.colors.textMuted;
      legendColor = config.colors.bodyColor;
      borderColor = config.colors.borderColor;
    }

    // ─── SWIPER: SLIDER PENJUALAN MINGGUAN ───
    // Carousel otomatis yang menampilkan data penjualan mingguan per kategori produk
    // Bergeser otomatis setiap 2.5 detik, bisa diklik paginationnya
    const swiperWithBgPagination = document.querySelector('#swiper-weekly-sales-with-bg');
    if (swiperWithBgPagination) {
      new Swiper(swiperWithBgPagination, {
        loop: true,         // Loop terus (setelah slide terakhir → kembali ke pertama)
        autoplay: { delay: 2500, disableOnInteraction: false },  // Otomatis geser
        pagination: { clickable: true, el: '.swiper-pagination' }  // Dot pagination bisa diklik
      });
    }

    // ─── SWIPER: SLIDER METODE PEMBAYARAN ───
    // Carousel yang menampilkan statistik per metode pembayaran (Cash, Transfer, dll)
    const swiperMarketingPagination = document.querySelector('#swiper-marketing-sales');
    if (swiperMarketingPagination) {
      new Swiper(swiperMarketingPagination, {
        loop: true,
        autoplay: { delay: 3000, disableOnInteraction: false },
        pagination: { clickable: true, el: '.swiper-pagination' }
      });
    }

    // ═══════════════════════════════════════════════════════════════
    // GRAFIK AREA: PENJUALAN BULAN INI
    // ═══════════════════════════════════════════════════════════════
    // Grafik area (area chart) yang menampilkan tren penjualan harian
    // selama bulan berjalan. Data diambil dari tag JSON Django.
    // Library: ApexCharts
    // ─────────────────────────────────────────────────────────────────
    const saleThisMonthChartEl = document.querySelector('#saleThisMonthChart'),
      // Ambil label tanggal dari JSON yang di-inject Django ke HTML
      chartLabelsEl = document.getElementById('sales-chart-labels'),
      chartLabels = chartLabelsEl ? JSON.parse(chartLabelsEl.textContent) : [],
      saleThisMonthChartConfig = {
        chart: {
          height: 120,         // Tinggi chart 120px (compact)
          type: 'area',        // Tipe: area chart (garis + fill di bawah)
          parentHeightOffset: 0,
          toolbar: { show: false },   // Sembunyikan toolbar chart
          sparkline: { enabled: true } // Mode sparkline (chart minimal tanpa axis)
        },
        grid: {
          xaxis: { lines: { show: false } },
          yaxis: { lines: { show: false } },
          padding: { top: 0, left: 0, right: 0, bottom: 0 }
        },
        tooltip: {
          enabled: true,
          x: { show: true, formatter: function(val, opts) { return 'Tgl ' + (chartLabels[opts.dataPointIndex] || val); } },
          y: { formatter: function(val) { return 'Rp ' + val.toLocaleString('id-ID'); } }
        },
        colors: [config.colors.primary],
        fill: {
          type: 'gradient',
          gradient: { shade: 'light', type: 'vertical', shadeIntensity: 0.4, opacityFrom: 0.8, opacityTo: 0.1, stops: [0, 100] }
        },
        stroke: { width: 2, curve: 'smooth' },
        series: [{ name: 'Penjualan', data: JSON.parse(document.getElementById('sales-chart-data').textContent) }],
        xaxis: {
          labels: { show: false },
          axisTicks: { show: false },
          axisBorder: { show: false },
          categories: chartLabels
        },
        yaxis: { min: 0, labels: { show: false } }
      };
    if (saleThisMonthChartEl) {
      const saleThisMonthChart = new ApexCharts(saleThisMonthChartEl, saleThisMonthChartConfig);
      saleThisMonthChart.render();
    }

    // ═══════════════════════════════════════════════════════════════
    // RADIAL BAR CHART: PEMBELIAN & BIAYA (Lingkaran Progress)
    // ═══════════════════════════════════════════════════════════════
    // Factory function untuk membuat konfigurasi radial bar chart.
    // Digunakan untuk chart lingkaran kecil (Total Pembelian & Total Biaya).
    // Parameter:
    //   color (string) — Warna chart (dari config.colors)
    //   value (number) — Persentase yang ditampilkan (0-100)
    //   icon (string)  — URL ikon di tengah lingkaran
    // ─────────────────────────────────────────────────────────────────
    function orderImpressionRadialBar(color, value, icon) {
      return {
        chart: {
          height: 90,
          width: 90,
          type: 'radialBar',
          sparkline: { enabled: true }
        },
        plotOptions: {
          radialBar: {
            hollow: { size: '52%', image: icon, imageWidth: 24, imageHeight: 24, imageClipped: false },
            track: { background: config.colors_label.secondary, strokeWidth: '100%' },
            dataLabels: { show: false }
          }
        },
        stroke: { lineCap: 'round' },
        colors: [color],
        series: [value],
        grid: { padding: { bottom: 0 } },
        responsive: [
          { breakpoint: 1400, options: { chart: { height: 100 } } },
          { breakpoint: 1380, options: { chart: { height: 96 } } },
          { breakpoint: 1354, options: { chart: { height: 93 } } },
          { breakpoint: 1336, options: { chart: { height: 88 } } },
          { breakpoint: 1286, options: { chart: { height: 84 } } },
          { breakpoint: 1258, options: { chart: { height: 80 } } },
          { breakpoint: 1200, options: { chart: { height: 98 } } }
        ]
      };
    }

    // Cari semua elemen chart radial bar di halaman
    // Setiap elemen punya atribut data-color, data-series, data-icon
    const chartProgressList = document.querySelectorAll('.chart-progress');
    if (chartProgressList) {
      chartProgressList.forEach(function (chartProgressEl) {
        const color = config.colors[chartProgressEl.dataset.color],  // Warna dari palet tema
          series = chartProgressEl.dataset.series,  // Nilai persentase
          icon = chartProgressEl.dataset.icon;      // URL ikon
        const options = orderImpressionRadialBar(color, series, icon);
        new ApexCharts(chartProgressEl, options).render();  // Render chart
      });
    }

    // ═══════════════════════════════════════════════════════════════
    // GRAFIK BAR: KEUNTUNGAN PER CABANG
    // ═══════════════════════════════════════════════════════════════
    // Bar chart vertikal yang membandingkan keuntungan kotor
    // antar gudang/cabang. Data dari live-visitors-data JSON.
    // Warna: hijau (success) untuk menandakan profit.
    // ─────────────────────────────────────────────────────────────────
    const liveVisitorsEl = document.querySelector('#liveVisitors'),
      liveVisitorsConfig = {
        chart: {
          height: 153,
          type: 'bar',
          parentHeightOffset: 0,
          toolbar: { show: false }
        },
        plotOptions: {
          bar: {
            borderRadius: 8,
            columnWidth: '43%',
            endingShape: 'rounded',
            startingShape: 'rounded'
          }
        },
        colors: [config.colors.success],
        grid: {
          padding: { top: -4, bottom: -7, left: -20, right: -2 },
          yaxis: { lines: { show: false } }
        },
        dataLabels: { enabled: false },
        series: [{ name: 'Profit', data: JSON.parse(document.getElementById('live-visitors-data').textContent) }],
        xaxis: {
          labels: { show: true, style: { colors: labelColor, fontSize: '11px', fontFamily: 'Inter' } },
          categories: [{% for nama in cabang_names %}'{{ nama }}'{% if not forloop.last %}, {% endif %}{% empty %} 'Cab1', 'Cab2', 'Cab3', 'Cab4', 'Cab5'{% endfor %}],
  axisTicks: { show: false },
  axisBorder: { show: false }
        },
  yaxis: { labels: { show: false } },
  legend: { show: false },
  responsive: [
    { breakpoint: 1443, options: { plotOptions: { bar: { borderRadius: 7 } } } },
    { breakpoint: 1372, options: { plotOptions: { bar: { borderRadius: 6 } } } },
    { breakpoint: 1248, options: { plotOptions: { bar: { borderRadius: 5 } } } },
    { breakpoint: 1200, options: { plotOptions: { bar: { borderRadius: 6 } } } },
    { breakpoint: 992, options: { plotOptions: { bar: { borderRadius: 8 } }, chart: { height: 156 } } },
    { breakpoint: 838, options: { plotOptions: { bar: { borderRadius: 6 } } } },
    { breakpoint: 644, options: { plotOptions: { bar: { borderRadius: 4 } } } },
    { breakpoint: 474, options: { plotOptions: { bar: { borderRadius: 7 } } } },
    { breakpoint: 383, options: { plotOptions: { bar: { borderRadius: 6 } } } }
  ]
      };
  if (liveVisitorsEl) {
    new ApexCharts(liveVisitorsEl, liveVisitorsConfig).render();
  }

  // ═══════════════════════════════════════════════════════════════
  // GRAFIK BAR: BIAYA PER KATEGORI
  // ═══════════════════════════════════════════════════════════════
  // Bar chart yang menampilkan pengeluaran biaya operasional
  // per kategori (Gaji, Sewa, Utilitas, Marketing, dll).
  // distributed: true → setiap bar bisa punya warna berbeda.
  // ─────────────────────────────────────────────────────────────────
  const visitsByDayChartEl = document.querySelector('#visitsByDayChart'),
    visitsByDayChartConfig = {
      chart: {
        height: 314,
        type: 'bar',
        parentHeightOffset: 0,
        toolbar: { show: false }
      },
      plotOptions: {
        bar: {
          borderRadius: 8,
          distributed: true,
          columnWidth: '55%',
          endingShape: 'rounded',
          startingShape: 'rounded'
        }
      },
      series: [{ name: 'Biaya', data: JSON.parse(document.getElementById('visits-by-day-data').textContent) }],
      legend: { show: false },
      dataLabels: { enabled: false },
      colors: [
        config.colors_label.primary, config.colors.primary, config.colors_label.primary,
        config.colors.primary, config.colors.primary, config.colors_label.primary, config.colors_label.primary
      ],
      grid: { show: false, padding: { top: -15, left: -7, right: -4 } },
      xaxis: {
        categories: [{% for nama in biaya_labels %}'{{ nama }}'{% if not forloop.last %}, {% endif %}{% empty %} 'Umum', 'Ops', 'Mkt', 'Lain', '-'{% endfor %}],

  axisTicks: { show: false }, axisBorder: { show: false },
  labels: { style: { colors: labelColor, fontSize: '13px', fontFamily: 'Inter' } }
        },
  yaxis: { show: false },
  responsive: [
    { breakpoint: 1240, options: { chart: { height: 307 } } },
    { breakpoint: 1200, options: { chart: { height: 327 } } },
    { breakpoint: 992, options: { chart: { height: 250 }, plotOptions: { bar: { columnWidth: '35%' } } } },
    { breakpoint: 577, options: { plotOptions: { bar: { columnWidth: '45%' } } } },
    { breakpoint: 477, options: { plotOptions: { bar: { columnWidth: '50%' } } } }
  ]
      };
  if (visitsByDayChartEl) {
    new ApexCharts(visitsByDayChartEl, visitsByDayChartConfig).render();
  }

  });

  // ═══════════════════════════════════════════════════════════════
  // FUNGSI MANAJEMEN USER DI DASHBOARD
  // ═══════════════════════════════════════════════════════════════

  // ─── TOGGLE STATUS USER (Aktif/Nonaktif) ───
  // Mengubah status aktif/nonaktif user dari tabel di dashboard
  // Saat ini masih placeholder, belum terintegrasi dengan backend
  function toggleUserStatus(userId) {
    if (confirm('Apakah Anda yakin ingin mengubah status user ini?')) {
      alert('Fitur toggle status akan diimplementasikan');
    }
  }

  // ─── HAPUS USER — Dengan Konfirmasi Modal ───
  // Variabel untuk menyimpan ID user yang akan dihapus
  let userToDelete = null;

  // Tampilkan modal konfirmasi hapus user
  // Parameter:
  //   userId (number) — ID user di database
  //   username (string) — Nama user (ditampilkan di modal)
  function confirmDeleteUser(userId, username) {
    userToDelete = userId;
    document.getElementById('deleteUserName').textContent = username;  // Isi nama di modal
    const modal = new bootstrap.Modal(document.getElementById('deleteUserModal'));
    modal.show();
  }

  // Eksekusi penghapusan user via AJAX POST
  // Dipanggil saat user klik tombol "Ya, Hapus User" di modal
  function deleteUser() {
    if (!userToDelete) return;

    // Loading state — disable tombol dan tampilkan spinner
    const confirmBtn = document.getElementById('confirmDeleteBtn');
    confirmBtn.disabled = true;
    confirmBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>Menghapus...';

    // Ambil CSRF token untuk autentikasi request Django
    const csrftoken = document.querySelector('[name=csrfmiddlewaretoken]').value;

    // Kirim AJAX POST ke endpoint hapus user
    fetch(`/users/delete/${userToDelete}/`, {
      method: 'POST',
      headers: {
        'X-CSRFToken': csrftoken,                     // Header CSRF wajib untuk POST
        'Content-Type': 'application/x-www-form-urlencoded',
      },
      credentials: 'same-origin'  // Kirim cookie session (untuk autentikasi)
    })
      .then(response => {
        if (response.ok) return response.text();  // Status 200-299 = berhasil
        throw new Error('Gagal menghapus user');
      })
      .then(() => {
        // Berhasil — tutup modal, tampilkan toast, reload halaman
        const modal = bootstrap.Modal.getInstance(document.getElementById('deleteUserModal'));
        modal.hide();
        showToast('success', 'User berhasil dihapus');
        setTimeout(() => window.location.reload(), 500);
      })
      .catch(error => {
        // Gagal — tampilkan pesan error dan kembalikan tombol
        console.error('Error:', error);
        showToast('danger', 'Gagal menghapus user. Silakan coba lagi.');
        confirmBtn.disabled = false;
        confirmBtn.innerHTML = '<i class="ri-delete-bin-line me-1"></i>Ya, Hapus User';
      });
  }

  // ─── SHOW TOAST — Notifikasi Pop-up via Bootstrap Toast ───
  // Membuat dan menampilkan notifikasi toast Bootstrap secara dinamis.
  // Toast = notifikasi kecil yang muncul di pojok halaman.
  // Parameter:
  //   type (string) — 'success' atau 'danger'
  //   message (string) — Pesan yang ditampilkan
  function showToast(type, message) {
    // Buat HTML toast secara dinamis
    const toastHtml = `
      <div class="bs-toast toast toast-placement-ex m-2 bg-${type} top-0 end-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="toast-header">
          <i class="ri-${type === 'success' ? 'check-line' : 'error-warning-line'} me-2"></i>
          <div class="me-auto fw-semibold">${type === 'success' ? 'Sukses' : 'Error'}</div>
          <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
        <div class="toast-body">${message}</div>
      </div>
    `;

    // Sisipkan toast ke dalam DOM dan tampilkan
    const toastContainer = document.createElement('div');
    toastContainer.innerHTML = toastHtml;
    document.body.appendChild(toastContainer);

    const toastElement = toastContainer.querySelector('.toast');
    const toast = new bootstrap.Toast(toastElement, { delay: 3000 });  // Auto-tutup 3 detik
    toast.show();

    // Hapus elemen dari DOM setelah toast tertutup (bersih-bersih)
    toastElement.addEventListener('hidden.bs.toast', () => {
      toastContainer.remove();
    });
  }

  // ═══════════════════════════════════════════════════════════════
  // FUNGSI FILTER DASHBOARD — Filter Tanggal
  // ═══════════════════════════════════════════════════════════════

  // Terapkan filter tanggal — redirect dengan query string
  // Contoh URL hasil: /?start_date=2024-01-01&end_date=2024-01-31
  function applyDashFilter() {
    const startDate = document.getElementById('dashStartDate').value;
    const endDate = document.getElementById('dashEndDate').value;
    const params = new URLSearchParams();  // Helper untuk membuat query string
    if (startDate) params.set('start_date', startDate);
    if (endDate) params.set('end_date', endDate);
    const qs = params.toString();
    window.location.href = '/' + (qs ? '?' + qs : '');  // Redirect ke dashboard dengan filter
  }

  // Reset filter — kembali ke dashboard tanpa filter
  function resetDashFilter() {
    window.location.href = '/';
  }

  // ═══════════════════════════════════════════════════════════════
  // JAM REALTIME — Update setiap detik
  // ═══════════════════════════════════════════════════════════════
  // Menampilkan jam digital realtime dengan format HH:MM:SS + zona waktu Indonesia
  // Zona waktu ditentukan dari offset: -420=WIB, -480=WITA, -540=WIT
  function updateDashClock() {
    const el = document.getElementById('dashRealtimeClock');
    if (!el) return;
    const now = new Date();
    const h = String(now.getHours()).padStart(2, '0');    // Jam (2 digit)
    const m = String(now.getMinutes()).padStart(2, '0');  // Menit (2 digit)
    // Deteksi zona waktu Indonesia berdasarkan timezone offset
    const tz = now.getTimezoneOffset();
    let tzLabel = 'WIB';                   // Default: Waktu Indonesia Barat
    if (tz === -480) tzLabel = 'WITA';     // Waktu Indonesia Tengah
    else if (tz === -540) tzLabel = 'WIT'; // Waktu Indonesia Timur
    el.textContent = h + ':' + m + ' ' + tzLabel;
  }
  setInterval(updateDashClock, 1000);  // Update setiap 1 detik (1000ms)
  document.addEventListener('DOMContentLoaded', updateDashClock);  // Jalankan pertama kali

  // ═══════════════════════════════════════════════════════════════
  // DETEKSI LOKASI via Geolocation API + OpenStreetMap Nominatim
  // ═══════════════════════════════════════════════════════════════
  // Alur: Browser minta izin lokasi → dapat koordinat GPS →
  //       kirim ke Nominatim API → dapat nama kota → tampilkan
  // Fallback: "Indonesia" jika user menolak atau terjadi error
  document.addEventListener('DOMContentLoaded', function() {
    const locEl = document.getElementById('dashLocation');
    if (!locEl) return;
    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(function(pos) {
        // Reverse geocoding: koordinat → nama tempat
        fetch('https://nominatim.openstreetmap.org/reverse?lat=' + pos.coords.latitude + '&lon=' + pos.coords.longitude + '&format=json&accept-language=id')
          .then(function(r) { return r.json(); })
          .then(function(data) {
            // Coba ambil nama kota/kabupaten dari respons Nominatim
            var city = data.address.city || data.address.town || data.address.village || data.address.county || '';
            var state = data.address.state || '';
            locEl.textContent = city + (state ? ', ' + state : '');
          })
          .catch(function() { locEl.textContent = 'Indonesia'; });  // Fallback jika API error
      }, function() {
        locEl.textContent = 'Indonesia';  // Fallback jika user menolak izin lokasi
      });
    } else {
      locEl.textContent = 'Indonesia';  // Fallback jika browser tidak support geolocation
    }
  });

  // ─── DETEKSI IP ADDRESS via ipify API ───
  // Mengambil IP publik pengguna dan menampilkannya di bar filter
  document.addEventListener('DOMContentLoaded', function() {
    var ipEl = document.getElementById('dashDeviceIP');
    if (!ipEl) return;
    fetch('https://api.ipify.org?format=json')
      .then(function(r) { return r.json(); })
      .then(function(data) { ipEl.textContent = data.ip; })  // Tampilkan IP
      .catch(function() { ipEl.textContent = '-'; });         // Fallback jika gagal
  });

  // ─── INISIALISASI BOOTSTRAP TOOLTIPS ───
  // Aktifkan semua tooltip di halaman (elemen dengan data-bs-toggle="tooltip")
  document.addEventListener('DOMContentLoaded', function() {
    var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
    tooltipTriggerList.map(function(el) {
      return new bootstrap.Tooltip(el);
    });
  });
</script>
{% endblock page_js %}

{# ══════════════════════════════════════════════════════════════════════ #}
{# KONTEN UTAMA DASHBOARD                                              #}
{# Layout: 2-column grid responsive dengan card-card komponen           #}
{# ══════════════════════════════════════════════════════════════════════ #}
{% block content %}
<!-- ═══ BAR FILTER WAKTU & STATUS ═══ -->
<!-- Bar horizontal berisi: input tanggal, tombol terapkan/reset, status filter, -->
<!-- jam realtime, lokasi GPS, dan IP address pengguna -->
<!-- Filter Waktu Dashboard -->
<style>
  /* ═══ Dashboard Filter Bar — Responsive ═══ */
  .dash-filter-card { border-color: rgba(255,255,255,.08) !important; }
  .dash-filter-card .card-body { padding: 10px 12px !important; }
  .dash-filter-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
  }
  /* Date Inputs */
  .dash-filter-dates {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .dash-filter-dates .input-group {
    min-width: 0;
    flex: 0 0 150px;
  }
  /* Tombol Aksi */
  .dash-filter-actions {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  /* Metadata: badge + jam + lokasi + IP */
  .dash-filter-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-left: auto;
  }
  /* Badge periode — tinggi & radius SAMA dengan btn-sm */
  .dash-filter-badge {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    height: 31px !important;
    font-size: .8rem !important;
    padding: 0 14px !important;
    line-height: 1 !important;
    white-space: nowrap !important;
    border-radius: .375rem !important; /* Sama dengan btn-sm Bootstrap */
  }
  /* Input & button height seragam */
  .dash-filter-bar .form-control,
  .dash-filter-bar .input-group-text {
    height: 31px !important;
    font-size: .8rem !important;
    padding-top: 0 !important;
    padding-bottom: 0 !important;
  }
  .dash-filter-bar .input-group-text { padding-left: 8px; padding-right: 8px; font-size: .75rem !important; }
  .dash-filter-bar .btn {
    height: 31px !important;
    font-size: .8rem !important;
    line-height: 1 !important;
  }

  /* ═══ DESKTOP ≥ 992px: Semua satu baris ═══ */
  @media (min-width: 992px) {
    .dash-filter-bar { flex-wrap: nowrap; }
    .dash-filter-dates .input-group { flex: 0 0 155px; }
  }

  /* ═══ TABLET 768-991px: 2 baris ═══ */
  @media (min-width: 768px) and (max-width: 991.98px) {
    .dash-filter-dates { flex: 1 1 100%; }
    .dash-filter-dates .input-group { flex: 1 1 0; }
    .dash-filter-actions { flex: 0 0 auto; }
    .dash-filter-meta { margin-left: auto; }
  }

  /* ═══ TABLET KECIL 577-767px: 2 baris ═══ */
  @media (min-width: 577px) and (max-width: 767.98px) {
    .dash-filter-dates { flex: 1 1 100%; }
    .dash-filter-dates .input-group { flex: 1 1 0; }
    .dash-filter-actions { flex: 0 0 auto; }
    .dash-filter-meta { margin-left: auto; }
  }

  /* ═══ MOBILE ≤ 576px: 3 baris, semuanya full-width ═══ */
  @media (max-width: 576px) {
    .dash-filter-card .card-body { padding: 8px 10px !important; }
    .dash-filter-bar { gap: 6px; }
    /* Baris 1: Tanggal */
    .dash-filter-dates {
      width: 100%;
      order: 1;
    }
    .dash-filter-dates .input-group {
      flex: 1 1 0;
      min-width: 0;
    }
    /* Baris 2: Tombol — melebar rata */
    .dash-filter-actions {
      width: 100%;
      order: 2;
      gap: 4px;
    }
    .dash-filter-actions .btn {
      flex: 1 1 0;
      min-width: 0;
      padding-left: 6px !important;
      padding-right: 6px !important;
    }
    /* Baris 3: Metadata — melebar rata */
    .dash-filter-meta {
      width: 100%;
      order: 3;
      margin-left: 0;
      gap: 6px;
    }
    .dash-filter-meta .dash-meta-item {
      display: inline-flex !important;
      font-size: .7rem !important;
    }
    .dash-filter-badge {
      flex: 0 0 auto;
    }
  }
</style>
<!-- ═══ BAR FILTER WAKTU & STATUS ═══ -->
<div class="card mb-4 shadow-none border dash-filter-card">
  <div class="card-body">
    <div class="dash-filter-bar">
      <!-- Tanggal Mulai & Selesai -->
      <div class="dash-filter-dates">
        <div class="input-group">
          <span class="input-group-text"><i class="ri-calendar-line ri-14px"></i></span>
          <input type="date" class="form-control" id="dashStartDate" value="{{ filter_start_date }}">
        </div>
        <span class="text-muted flex-shrink-0" style="font-size:.75rem;">—</span>
        <div class="input-group">
          <span class="input-group-text"><i class="ri-calendar-line ri-14px"></i></span>
          <input type="date" class="form-control" id="dashEndDate" value="{{ filter_end_date }}">
        </div>
      </div>
      <!-- Tombol Filter -->
      <div class="dash-filter-actions">
        <button class="btn btn-primary btn-sm px-3" onclick="applyDashFilter()">
          <i class="ri-filter-3-line ri-14px me-1"></i>Terapkan
        </button>
        <button class="btn btn-label-secondary btn-sm px-2" onclick="resetDashFilter()">
          <i class="ri-refresh-line ri-14px me-1"></i>Refresh
        </button>
        <button class="btn btn-label-secondary btn-sm px-2" onclick="window.location.reload()" title="Refresh Halaman">
          <i class="ri-loop-left-line ri-14px"></i>
        </button>
      </div>
      <!-- Metadata: Status Periode + Jam + Lokasi + IP -->
      <div class="dash-filter-meta">
        {% if has_date_filter %}
        <span class="badge bg-label-primary dash-filter-badge"><i class="ri-filter-line ri-12px me-1"></i>Filter Aktif</span>
        {% else %}
        <span class="badge bg-label-secondary dash-filter-badge">Semua Periode</span>
        {% endif %}
        <span class="dash-meta-item d-none d-md-inline-flex align-items-center gap-1 text-muted" style="font-size:.75rem;">
          <i class="ri-time-line ri-12px"></i>
          <span id="dashRealtimeClock">--:--</span>
        </span>
        <span class="dash-meta-item d-none d-lg-inline-flex align-items-center gap-1 text-muted" style="font-size:.75rem;">
          <i class="ri-map-pin-line ri-12px"></i>
          <span id="dashLocation">...</span>
        </span>
        <span class="dash-meta-item d-none d-xl-inline-flex align-items-center gap-1 text-muted" style="font-size:.75rem;">
          <i class="ri-global-line ri-12px"></i>
          <span id="dashDeviceIP">...</span>
        </span>
      </div>
    </div>
  </div>
</div>

<div class="row g-6 mb-6">
  <!-- ROW 1: Ringkasan Penjualan + Estimasi + Profit + Slider + Chart Sparkline -->
  <!-- Ringkasan Penjualan (Sales Overview) -->
  <!-- Card 3 kolom: Total Aset, Total Harga Beli, Total Harga Jual -->
  <!-- Data dari: sales_overview context variable -->
  <div class="col-lg-6">
    <div class="card h-100">
      <div class="card-header">
        <div class="d-flex justify-content-between">
          <h5 class="mb-1">Ringkasan Penjualan</h5>
          <div class="dropdown">
            <button class="btn btn-text-secondary rounded-pill text-muted border-0 p-1" type="button"
              data-bs-toggle="dropdown">
              <i class="ri-more-2-line ri-20px"></i>
            </button>
            <div class="dropdown-menu dropdown-menu-end">
              <a class="dropdown-item" href="javascript:window.location.reload();"><i class="ri-loop-left-line me-2"></i>Refresh Data</a>
              <a class="dropdown-item" href="{% url 'laporan:keuangan' %}"><i class="ri-file-chart-line me-2"></i>Lihat Laporan</a>
              <a class="dropdown-item" href="{% url 'penjualan:sales-order' %}"><i class="ri-shopping-cart-line me-2"></i>Lihat Penjualan</a>
            </div>
          </div>
        </div>
        <div class="d-flex align-items-center card-subtitle">
          <div class="me-2">Total {{ sales_overview.total_sales }} Penjualan</div>
          <div class="d-flex align-items-center text-success">
            <p class="mb-0 fw-medium">+{{ sales_overview.growth }}%</p>
            <i class="ri-arrow-up-s-line ri-20px"></i>
          </div>
        </div>
      </div>
      <div class="card-body d-flex justify-content-between flex-wrap gap-4">
        <div class="d-flex align-items-center gap-3">
          <div class="avatar">
            <div class="avatar-initial bg-label-primary rounded">
              <i class="ri-safe-2-line ri-24px"></i>
            </div>
          </div>
          <div class="card-info">
            <h5 class="mb-0" data-bs-toggle="tooltip" data-bs-placement="top" title="Total harga beli × (stok saat ini + qty terjual) dari semua produk yang pernah masuk ke sistem">{{ sales_overview.total_keseluruhan_aset|rupiah }}</h5>
            <p class="mb-0">Total Aset</p>
          </div>
        </div>
        <div class="d-flex align-items-center gap-3">
          <div class="avatar">
            <div class="avatar-initial bg-label-danger rounded">
              <i class="ri-shopping-cart-2-line ri-24px"></i>
            </div>
          </div>
          <div class="card-info">
            <h5 class="mb-0" data-bs-toggle="tooltip" data-bs-placement="top" title="Total harga beli × stok dari produk yang masih tersedia (stok > 0)">{{ sales_overview.total_harga_beli|rupiah }}</h5>
            <p class="mb-0">Total Harga Beli</p>
          </div>
        </div>
        <div class="d-flex align-items-center gap-3">
          <div class="avatar">
            <div class="avatar-initial bg-label-success rounded">
              <i class="ri-price-tag-3-line ri-24px"></i>
            </div>
          </div>
          <div class="card-info">
            <h5 class="mb-0" data-bs-toggle="tooltip" data-bs-placement="top" title="Total harga jual × stok dari produk yang masih tersedia (stok > 0)">{{ sales_overview.total_harga_jual|rupiah }}</h5>
            <p class="mb-0">Total Harga Jual</p>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!--/ Sales Overview-->

  <!-- Estimasi Keuntungan -->
  <div class="col-lg-3 col-sm-6">
    <div class="card h-100">
      <div class="card-body position-relative">
        <div class="card-info mb-3">
          <h6 class="mb-2 text-nowrap">Total Target Keuntungan</h6>
          <div class="badge {% if sales_overview.estimasi_keuntungan >= 0 %}bg-label-success{% else %}bg-label-danger{% endif %} rounded-pill lh-xs">
            {% if sales_overview.estimasi_keuntungan >= 0 %}Estimasi Keuntungan{% else %}Loss{% endif %}
          </div>
        </div>
        <div class="d-flex align-items-center flex-wrap gap-2">
          <h3 class="mb-0" data-bs-toggle="tooltip" data-bs-placement="top" title="Selisih antara Total Harga Jual dan Total Harga Beli dari produk yang masih ready (stok > 0)">{{ sales_overview.estimasi_keuntungan|rupiah }}</h3>
        </div>
        <small class="{% if sales_overview.estimasi_keuntungan >= 0 %}text-success{% else %}text-danger{% endif %} fw-medium mt-1 d-block">Produk ready (stok > 0)</small>
        <div class="position-absolute" style="top: 1.5rem; right: 1.5rem;">
          <div class="avatar">
            <div class="avatar-initial {% if sales_overview.estimasi_keuntungan >= 0 %}bg-label-success{% else %}bg-label-danger{% endif %} rounded">
              <i class="ri-line-chart-line ri-26px"></i>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!--/ Estimasi Keuntungan -->

  <!-- Keuntungan (Profit) -->
  <div class="col-lg-3 col-sm-6">
    <div class="card h-100">
      <div class="card-body position-relative">
        <div class="card-info mb-3">
          <h6 class="mb-2 text-nowrap">Keuntungan Kotor</h6>
          <div
            class="badge {% if profit_data.is_profit %}bg-label-success{% else %}bg-label-danger{% endif %} rounded-pill lh-xs">
            {% if profit_data.is_profit %}Keuntungan{% else %}Loss{% endif %}</div>
        </div>
        <div class="mb-2">
          <h4 class="mb-0 text-truncate" data-bs-toggle="tooltip" data-bs-placement="top" title="Keuntungan kotor = (Harga Jual − Harga Beli) × Jumlah terjual, dari Sales Order + POS Transaction">{{ profit_data.gross_profit|rupiah }}</h4>
        </div>
        <div>
          <small class="{% if profit_data.is_profit %}text-success{% else %}text-danger{% endif %} fw-medium" data-bs-toggle="tooltip" data-bs-placement="bottom" title="Profit Margin = Keuntungan Kotor ÷ Total Pendapatan × 100%">{% if profit_data.is_profit %}+{% endif %}{{ profit_data.margin_percent }}% margin</small>
        </div>
        <div class="position-absolute" style="top: 1.5rem; right: 1.5rem;">
          <div class="avatar">
            <div
              class="avatar-initial {% if profit_data.is_profit %}bg-label-success{% else %}bg-label-danger{% endif %} rounded">
              <i class="ri-money-dollar-circle-line ri-26px"></i>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!--/ Keuntungan -->

  <!-- Weekly Sales with bg-->
  <div class="col-lg-6">
    <div class="swiper-container swiper-container-horizontal swiper text-bg-primary h-100"
      id="swiper-weekly-sales-with-bg">
      <div class="swiper-wrapper">
        {% for week_data in weekly_sales_data %}
        <div class="swiper-slide pb-5">
          <div class="row">
            <div class="col-12">
              <h5 class="text-white mb-0">{{ week_data.category }}</h5>
              <div class="d-flex align-items-center gap-2">
                <div>Total {{ week_data.earning }} Pendapatan</div>
                <div class="d-flex align-items-center text-success">
                  <p class="mb-0 fw-medium">{{ week_data.growth }} Trx</p>
                </div>
              </div>
            </div>
            <div class="col-lg-7 col-md-9 col-12 order-2 order-md-1">
              <h6 class="text-white mt-0 mt-md-4 mb-4 py-1">{{ week_data.category }}</h6>
              <div class="row g-2">
                {% for item in week_data.items %}
                <div class="col-6">
                  <div class="d-flex mb-2 align-items-center">
                    <p class="mb-0 me-2 weekly-sales-text-bg-primary fw-medium">{{ item.count }}</p>
                    <p class="mb-0 text-truncate" style="font-size: 0.85rem;">{{ item.name }}</p>
                  </div>
                </div>
                {% endfor %}
              </div>
            </div>
            <div class="col-lg-5 col-md-3 col-12 order-1 order-md-2 my-2 my-md-0 text-center">
              {% if week_data.product_image %}
              <img src="{{ week_data.product_image.url }}" alt="{{ week_data.category }}" width="200"
                class="weekly-sales-img rounded-3" style="object-fit: cover; max-height: 200px;">
              {% else %}
              <img src="{% static 'img/products/card-weekly-sales-phone.png' %}" alt="{{ week_data.category }}"
                width="200" class="weekly-sales-img">
              {% endif %}
            </div>
          </div>
        </div>
        {% endfor %}
      </div>
      <div class="swiper-pagination"></div>
    </div>
  </div>
  <!--/ Weekly Sales with bg-->

  <!-- Total Visits -->
  <div class="col-lg-3 col-sm-6">
    <div class="card h-100">
      <div class="card-header">
        <div class="d-flex justify-content-between flex-wrap gap-2">
          <p class="d-block mb-0 text-body">Gudang & Produk</p>
          <div class="d-flex align-items-center">
            <div class="avatar">
              <div class="avatar-initial bg-label-success rounded">
                <i class="ri-checkbox-circle-line ri-24px"></i>
              </div>
            </div>
          </div>
        </div>
        <h4 class="mb-0" data-bs-toggle="tooltip" data-bs-placement="top" title="Jumlah gudang/cabang aktif yang terdaftar dalam sistem">{{ cabang_data.total_gudang }} Gudang</h4>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-5">
            <div class="d-flex gap-2 align-items-center mb-2">
              <div class="avatar avatar-xs flex-shrink-0">
                <div class="avatar-initial rounded bg-label-warning">
                  <i class="ri-home-8-line ri-16px"></i>
                </div>
              </div>
              <p class="mb-0">Gudang</p>
            </div>
            <h4 class="mb-2" data-bs-toggle="tooltip" data-bs-placement="top" title="Jumlah gudang/cabang yang aktif">{{ cabang_data.total_gudang }}</h4>
          </div>
          <div class="col-2">
            <div class="divider divider-vertical">
              <div class="divider-text">
                <span class="badge-divider-bg">:</span>
              </div>
            </div>
          </div>
          <div class="col-5 text-end">
            <div class="d-flex gap-2 justify-content-end align-items-center mb-2">
              <p class="mb-0">Produk</p>
              <div class="avatar avatar-xs flex-shrink-0">
                <div class="avatar-initial rounded bg-label-primary">
                  <i class="ri-box-3-line ri-16px"></i>
                </div>
              </div>
            </div>
            <h4 class="mb-2" data-bs-toggle="tooltip" data-bs-placement="top" title="Total produk aktif yang tersedia di sistem">{{ cabang_data.total_produk }}</h4>
          </div>
        </div>
        <div class="d-flex align-items-center mt-4">
          <div class="progress w-100 rounded" style="height: 8px;">
            <div class="progress-bar bg-warning" style="width: {{ cabang_data.gudang_percent }}%" role="progressbar">
            </div>
            <div class="progress-bar bg-primary" role="progressbar" style="width: {{ cabang_data.produk_percent }}%">
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!--/ Total Visits -->

  <!-- Sales This Months -->
  <div class="col-lg-3 col-sm-6">
    <div class="card h-100">
      <div class="card-body position-relative">
        <div class="card-info mb-3">
          <h5 class="mb-2">Bulan Ini</h5>
          <p class="mb-0">Total Penjualan</p>
          <h5 class="mb-0" data-bs-toggle="tooltip" data-bs-placement="top" title="Total penjualan bulan ini dari Sales Order + Transaksi POS yang sudah lunas">{{ sales_this_month|rupiah }}</h5>
        </div>
        <div class="position-absolute" style="top: 1.5rem; right: 1.5rem;">
          <div class="avatar">
            <div class="avatar-initial bg-label-primary rounded">
              <i class="ri-line-chart-line ri-24px"></i>
            </div>
          </div>
        </div>
        <div id="saleThisMonthChart"></div>
      </div>
    </div>
  </div>
  <!--/ Sales This Months -->
</div>

<div class="row g-6 mb-6">
  <!-- Activity Timeline -->
  <div class="col-12 col-md-7 col-xl-6 order-md-2 order-xl-0">
    <div class="card h-100">
      <div class="card-header">
        <div class="d-flex justify-content-between">
          <h5 class="mb-0">Aktivitas Terkini</h5>
        </div>
      </div>
      <div class="card-body pt-4">
        <ul class="timeline card-timeline mb-0">
          {% for activity in activity_timeline %}
          <li class="timeline-item timeline-item-transparent">
            <span class="timeline-point timeline-point-{{ activity.color }}"></span>
            <div class="timeline-event">
              <div class="timeline-header mb-3">
                <h6 class="mb-0">{{ activity.title }}</h6>
                <small class="text-muted">{{ activity.time }}</small>
              </div>
              <p class="mb-2">{{ activity.desc }}</p>
              {% if activity.file %}
              <div class="d-flex align-items-center mb-1">
                <div class="badge bg-lighter rounded-3">
                  <img src="{% static 'img/icons/misc/pdf.png' %}" alt="img" width="15" class="me-2">
                  <span class="h6 mb-0 text-body">{{ activity.file }}</span>
                </div>
              </div>
              {% endif %}
              {% if activity.users %}
              <div class="d-flex justify-content-between flex-wrap gap-2">
                <div class="d-flex flex-wrap align-items-center">
                  <ul class="list-unstyled users-list d-flex align-items-center avatar-group m-0">
                    {% for user_img in activity.users %}
                    <li class="avatar pull-up">
                      <img class="rounded-circle" src="{% static 'img/avatars/'|add:user_img %}" alt="Avatar" />
                    </li>
                    {% endfor %}
                  </ul>
                </div>
              </div>
              {% endif %}
            </div>
          </li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>
  <!--/ Activity Timeline -->

  <!-- Top Products Table -->
  <div class="col-12 col-md-5 col-xl-6 order-md-1 order-xl-0">
    <div class="card h-100">
      <div class="card-header d-flex justify-content-between">
        <h5 class="mb-0">Produk Terlaris</h5>
        <div class="dropdown">
          <button class="btn btn-text-secondary rounded-pill text-muted border-0 p-1" type="button"
            data-bs-toggle="dropdown">
            <i class="ri-more-2-line ri-20px"></i>
          </button>
          <div class="dropdown-menu dropdown-menu-end">
            <a class="dropdown-item" href="{% url 'produk:list' %}">Lihat Semua Produk</a>
            <a class="dropdown-item" href="javascript:window.location.reload();"><i class="ri-loop-left-line me-2"></i>Refresh Data</a>
          </div>
        </div>
      </div>
      <div class="table-responsive">
        <table class="table table-borderless">
          <thead>
            <tr>
              <th>Produk</th>
              <th>Status</th>
              <th>Revenue</th>
              <th>Profit</th>
            </tr>
          </thead>
          <tbody>
            {% for product in top_products %}
            <tr>
              <td>
                <div class="d-flex align-items-center">
                  <div class="avatar avatar-sm me-3">
                    {% if product.image %}
                    <img src="{{ product.image.url }}" alt="{{ product.name }}" class="rounded">
                    {% else %}
                    <span class="avatar-initial rounded bg-label-primary">
                      <i class="ri-product-hunt-line ri-20px"></i>
                    </span>
                    {% endif %}
                  </div>
                  <div>
                    <h6 class="mb-0 text-truncate" style="max-width: 150px;">{{ product.name }}</h6>
                    <small class="text-muted">{{ product.sku }}</small>
                  </div>
                </div>
              </td>
              <td><span class="badge bg-label-{{ product.status_class }}">{{ product.status }}</span></td>
              <td>
                <div>
                  <p class="mb-0 fw-medium">{{ product.revenue|rupiah }}</p>
                  <small class="text-muted">{{ product.qty_sold }} terjual</small>
                </div>
              </td>
              <td>
                <div class="d-flex align-items-center">
                  <p class="mb-0 {% if product.profit >= 0 %}text-success{% else %}text-danger{% endif %}">
                    {% if product.profit >= 0 %}+{% endif %}{{ product.profit_percentage }}%
                  </p>
                </div>
              </td>
            </tr>
            {% empty %}
            <tr>
              <td colspan="4" class="text-center py-4">
                <p class="text-muted mb-0">Belum ada data penjualan produk</p>
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <!--/ Top Products Table -->

  <!-- Total Impression & Order Chart -->
  <div class="col-lg-3 col-sm-6">
    <div class="card h-100">
      <div class="card-body pb-0">
        <div class="d-flex align-items-center gap-4">
          <div>
            <div class="chart-progress" data-color="primary" data-series="70"
              data-icon="{% static 'img/icons/misc/card-icon-laptop.png' %}"></div>
          </div>
          <div>
            <div class="card-info">
              <div class="d-flex align-items-center gap-2 flex-wrap">
                <h5 class="mb-0" data-bs-toggle="tooltip" data-bs-placement="top" title="Total nilai semua Purchase Order yang berstatus Approved atau Received">{{ pembelian_data.total_value|rupiah }}</h5>
                <div class="d-flex align-items-start text-success">
                  <i class="ri-shopping-bag-line ri-20px"></i>
                </div>
              </div>
              <p class="mb-0 mt-1">Total Pembelian</p>
            </div>
          </div>
        </div>
      </div>
      <hr class="my-4">
      <div class="card-body pt-0">
        <div class="d-flex align-items-center gap-4">
          <div>
            <div class="chart-progress" data-color="warning" data-series="40"
              data-icon="{% static 'img/icons/misc/card-icon-bag.png' %}"></div>
          </div>
          <div>
            <div class="card-info">
              <div class="d-flex align-items-center gap-2 flex-wrap">
                <h5 class="mb-0" data-bs-toggle="tooltip" data-bs-placement="top" title="Total semua pengeluaran operasional (biaya gaji, sewa, utilitas, dll) yang tercatat di modul Biaya">{{ biaya_total|rupiah }}</h5>
                <div class="d-flex align-items-center text-warning">
                  <i class="ri-money-dollar-circle-line ri-20px"></i>
                </div>
              </div>
              <p class="mb-0 mt-1">Total Biaya</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!--/ Total Impression & Order Chart -->

  <!-- Marketing & Sales (Metode Pembayaran Slider) -->
  <div class="col-lg-5 col-sm-6">
    <div class="swiper-container swiper-container-horizontal swiper swiper-sales" id="swiper-marketing-sales">
      <div class="swiper-wrapper">
        {% for ms in marketing_sales_data %}
        <div class="swiper-slide card pb-5 shadow-none border-0">
          <h5 class="mb-1">{{ ms.title }}</h5>
          <div class="d-flex align-items-center card-subtitle gap-2">
            <div>{{ ms.total }}</div>
            <div class="d-flex align-items-center text-success">
              <p class="mb-0 fw-medium">{{ ms.growth }}%</p>
              <i class="ri-pie-chart-2-line ri-18px ms-1"></i>
            </div>
          </div>
          <div class="d-flex align-items-center mt-4">
            {% if ms.product_image %}
            <img src="{{ ms.product_image.url }}" alt="{{ ms.title }}" width="80" class="rounded-4 flex-shrink-0" style="object-fit: cover; height: 80px;">
            {% else %}
            <div class="rounded-4 bg-label-primary d-flex align-items-center justify-content-center flex-shrink-0" style="width: 80px; height: 80px;">
              <i class="ri-bank-card-line ri-32px"></i>
            </div>
            {% endif %}
            <div class="d-flex flex-column w-100 ms-4">
              <h6 class="mb-3">Statistik</h6>
              <div class="row g-3">
                {% for stat in ms.stats %}
                <div class="col-6">
                  <span class="payment-stat-badge" data-bs-toggle="tooltip" data-bs-placement="top" title="{{ stat.label }}: {{ stat.value }}">{{ stat.value }}</span>
                  <small class="d-block text-muted mt-1 text-center" style="font-size: 0.7rem;">{{ stat.label }}</small>
                </div>
                {% endfor %}
              </div>
            </div>
          </div>
          <div class="mt-4">
            {% if ms.id %}
            <a href="{% url 'pengaturan:metode_pembayaran_detail' ms.id %}" class="btn btn-sm btn-outline-primary me-3">Details</a>
            {% else %}
            <button type="button" class="btn btn-sm btn-outline-primary me-3" disabled>Details</button>
            {% endif %}
            <a href="{% url 'laporan:keuangan' %}" class="btn btn-sm btn-primary">Report</a>
          </div>
        </div>
        {% endfor %}
      </div>
      <div class="swiper-pagination"></div>
    </div>
  </div>
  <!--/ Marketing & Sales (Metode Pembayaran Slider) -->

  <!-- Live Visitors-->
  <div class="col-lg-4 col-md-6 order-md-3 order-lg-0">
    <div class="card h-100">
      <div class="card-header">
        <div class="d-flex justify-content-between mb-1">
          <h5 class="mb-0" data-bs-toggle="tooltip" data-bs-placement="top" title="Perbandingan keuntungan kotor per gudang/cabang, dihitung dari (Harga Jual − Harga Beli) × Jumlah terjual untuk produk di masing-masing cabang">Keuntungan per Cabang</h5>
          <div class="d-flex text-success">
            <i class="ri-money-dollar-circle-line ri-20px"></i>
          </div>
        </div>
        <p class="card-subtitle mb-0" data-bs-toggle="tooltip" data-bs-placement="bottom" title="Jumlah gudang/cabang yang aktif beroperasi saat ini">{{ cabang_data.total_gudang }} Cabang Aktif</p>
      </div>
      <div class="card-body">
        <div id="liveVisitors"></div>
      </div>
    </div>
  </div>
  <!--/ Live Visitors-->

  <!-- User Table (Replaces Roles Datatable) -->
  <div class="col-xl-8 col-md-7 col-12">
    <div class="card h-100">
      <div class="card-header">
        <h5 class="mb-0">Pengguna Terbaru</h5>
      </div>
      <div class="table-responsive rounded-3">
        <table class="table table-hover table-border-bottom-0">
          <thead>
            <tr>
              <th>User</th>
              <th>Email</th>
              <th>Role</th>
              <th>Status</th>
              <th>Aksi</th>
            </tr>
          </thead>
          <tbody>
            {% for user in latest_users %}
            <tr>
              <td>
                <div class="d-flex align-items-center">
                  <div class="avatar avatar-sm me-3">
                    <span class="avatar-initial rounded-circle bg-label-primary">{{ user.username|slice:":2"|upper }}</span>
                  </div>
                  <div>
                    <span class="fw-medium d-block">{{ user.username }}</span>
                    <small class="text-muted">@{{ user.username|lower }}</small>
                  </div>
                </div>
              </td>
              <td><span class="text-truncate d-block" style="max-width: 200px;">{{ user.email }}</span></td>
              <td>
                <div class="d-flex align-items-center">
                  <i class="{{ user.role_icon }} ri-18px text-{{ user.role_color }} me-2"></i>
                  <span>{{ user.role }}</span>
                </div>
              </td>
              <td><span class="badge rounded-pill bg-label-{{ user.status_class }}">{{ user.status }}</span></td>
              <td>
                <div class="dropdown">
                  <button class="btn btn-sm btn-icon btn-text-secondary" data-bs-toggle="dropdown">
                    <i class="ri-more-2-line"></i>
                  </button>
                  <div class="dropdown-menu dropdown-menu-end">
                    <a class="dropdown-item" href="{% url 'user_management:user_detail' user.id %}"><i
                        class="ri-eye-line me-2"></i>Detail User</a>
                    <a class="dropdown-item" href="{% url 'user_management:user_edit' user.id %}"><i
                        class="ri-edit-line me-2"></i>Edit User</a>
                    <a class="dropdown-item" href="#" onclick="toggleUserStatus({{ user.id }})"><i
                        class="ri-toggle-line me-2"></i>Toggle Status</a>
                    <div class="dropdown-divider"></div>
                    <a class="dropdown-item text-danger" href="#"
                      onclick="confirmDeleteUser({{ user.id }}, '{{ user.username }}'); return false;"><i
                        class="ri-delete-bin-line me-2"></i>Hapus User</a>
                  </div>
                </div>
              </td>
            </tr>
            {% empty %}
            <tr>
              <td colspan="5" class="text-center py-4">
                <p class="text-muted mb-0">Belum ada pengguna</p>
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <!--/ Roles Datatables -->

  <!-- visits By Day Chart-->
  <div class="col-xl-4 col-md-5 col-12 order-md-1 order-xl-0">
    <div class="card h-100">
      <div class="card-header">
        <div class="d-flex justify-content-between">
          <h5 class="mb-1" data-bs-toggle="tooltip" data-bs-placement="top" title="Visualisasi pengeluaran biaya operasional per kategori biaya (gaji, sewa, utilitas, dll)">Biaya per Kategori</h5>
        </div>
        <p class="mb-0 card-subtitle" data-bs-toggle="tooltip" data-bs-placement="bottom" title="Akumulasi semua biaya operasional yang tercatat di modul Biaya">Total {{ biaya_total|rupiah }} Biaya</p>
      </div>
      <div class="card-body">
        <div id="visitsByDayChart"></div>
        <div class="d-flex justify-content-between mt-4">
          <div>
            <h6 class="mb-0" data-bs-toggle="tooltip" data-bs-placement="top" title="Total biaya dibagi jumlah cabang aktif">Rata-rata Biaya</h6>
            <p class="mb-0 small">{{ expense_per_cabang|rupiah }} (Avg)</p>
          </div>
          <div class="avatar">
            <div class="avatar-initial bg-label-primary rounded">
              <i class="ri-arrow-right-s-line ri-24px scaleX-n1-rtl"></i>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!--/ visits By Day Chart-->
</div>

<!-- Delete User Modal -->
<div class="modal fade" id="deleteUserModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-label-danger">
        <h5 class="modal-title text-danger">
          <i class="ri-alert-line me-2"></i>Konfirmasi Hapus User
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="alert alert-danger d-flex align-items-start" role="alert">
          <i class="ri-error-warning-line ri-22px me-2"></i>
          <div>
            <h6 class="alert-heading mb-1">Peringatan!</h6>
            <span>Tindakan ini akan menghapus user secara permanen dan <strong>tidak dapat dibatalkan</strong>.</span>
          </div>
        </div>
        <div class="card bg-lighter mb-3">
          <div class="card-body">
            <div class="d-flex align-items-center">
              <div class="avatar avatar-md me-3">
                <span class="avatar-initial rounded bg-label-primary">
                  <i class="ri-user-line ri-24px"></i>
                </span>
              </div>
              <div>
                <h6 class="mb-0" id="deleteUserName"></h6>
                <small class="text-muted">User akan dihapus secara permanen</small>
              </div>
            </div>
          </div>
        </div>
        <p class="mb-2">Apakah Anda yakin ingin menghapus user ini?</p>
        <p class="text-muted small mb-0">
          <i class="ri-information-line me-1"></i>
          Semua data dan riwayat yang terkait dengan user ini akan dihapus.
        </p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">
          <i class="ri-close-line me-1"></i>Batal
        </button>
        <button type="button" class="btn btn-danger" id="confirmDeleteBtn" onclick="deleteUser()">
          <i class="ri-delete-bin-line me-1"></i>Ya, Hapus User
        </button>
      </div>
    </div>
  </div>
</div>
{% endblock content %}
