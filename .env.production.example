# ==========================================================================
# SIMKOS — Production Environment Variables (.env)
# ==========================================================================
# Copy file ini ke .env dan sesuaikan nilai-nilainya.
# JANGAN commit file .env ke repository!
# ==========================================================================

# --- Core Django ---
DEBUG=False
DJANGO_ENVIRONMENT=production
SECRET_KEY=GANTI_DENGAN_RANDOM_KEY_50_KARAKTER

# --- Domain & Hosts ---
ALLOWED_HOSTS=.simkos.serpgroup.cloud,.serpgroup.cloud
CSRF_TRUSTED_ORIGINS=https://*.simkos.serpgroup.cloud,https://simkos.serpgroup.cloud
BASE_URL=https://simkos.serpgroup.cloud

# Cookie domain — agar session berlaku untuk semua subdomain tenant
SESSION_COOKIE_DOMAIN=.simkos.serpgroup.cloud

# --- PostgreSQL Database ---
DATABASE_ENGINE=postgresql
DATABASE_NAME=simkos_db
DATABASE_USER=simkos_user
DATABASE_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT
DATABASE_HOST=localhost
DATABASE_PORT=5432

# --- CLS (Central License Server) Connection ---
LICENSE_SERVER_URL=https://cls.serpgroup.cloud

# --- Internal API Key (untuk komunikasi dengan CLS) ---
SAAS_INTERNAL_API_KEY=GANTI_DENGAN_RANDOM_API_KEY

# --- Device Identity ---
DEVICE_NAME=SIMKOS Production Server
