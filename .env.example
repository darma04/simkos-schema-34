# ==========================================================================
#  ENVIRONMENT VARIABLES — Template Konfigurasi
# ==========================================================================
#  CARA PAKAI:
#  1. Copy file ini: cp .env.example .env
#  2. Isi semua nilai yang bertanda [WAJIB DIISI]
#  3. JANGAN commit file .env ke Git! (sudah di .gitignore)
#
#  File ini AMAN untuk di-commit karena TIDAK berisi nilai rahasia.
# ==========================================================================

# --- Django Core ---

# [WAJIB DIISI] Secret key untuk keamanan Django (enkripsi session, CSRF, dll)
# Generate dengan: python -c "import secrets; print(secrets.token_urlsafe(50))"
# PERINGATAN: Jika key ini bocor, penyerang bisa memalsukan session user!
SECRET_KEY=

# Mode debug: True untuk development, False untuk production
# PERINGATAN: DEBUG=True di produksi menampilkan stack trace ke publik!
DEBUG=True

# Environment: local / production
DJANGO_ENVIRONMENT=local

# --- Hosts & Origins ---

# Domain yang diizinkan mengakses aplikasi
# Development: localhost,127.0.0.1
# Production: serp.pythonanywhere.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Domain yang diizinkan mengirim form (CSRF protection)
# Development: http://127.0.0.1,http://localhost
# Production: https://serp.pythonanywhere.com
CSRF_TRUSTED_ORIGINS=http://127.0.0.1,http://localhost

# URL dasar aplikasi (untuk link di email, dll)
BASE_URL=http://127.0.0.1:8000

# --- Email (Opsional) ---

# Untuk fitur reset password via email
# Gunakan App Password Gmail: https://myaccount.google.com/apppasswords
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
